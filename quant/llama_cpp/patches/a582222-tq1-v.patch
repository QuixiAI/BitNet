+        else throw std::runtime_error("unsupported TQ1 profile '" + profile + "'");
+        if (tensor_it->second->type != expected_type || tensor_it->second->extra != nullptr) {
+            throw std::runtime_error("TQ1 GGML type or backend binding mismatch for '" + name + "'");
