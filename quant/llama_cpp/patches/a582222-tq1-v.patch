 // ggml_compute_forward_mul_mat
 
+static bool ggml_type_is_tq1_v(enum ggml_type type) {
+    return type == GGML_TYPE_TQ1_V11 || type == GGML_TYPE_TQ1_V12 ||
+           type == GGML_TYPE_TQ1_V11_R || type == GGML_TYPE_TQ1_V12_R ||
+           type == GGML_TYPE_TQ1_V11_J_A4_R;
+}
+
+static uint32_t ggml_tq1_v_index(const uint8_t * block, int offset, int high_bits, int group) {
+    const uint8_t * low = block + offset;
+    const uint8_t * high = low + 32;
+    const int bit = group * high_bits;
+    const int byte = bit >> 3;
+    const int shift = bit & 7;
+    uint32_t word = high[byte];
+    const int high_bytes = high_bits * 4;
+    if (byte + 1 < high_bytes) {
+        word |= (uint32_t) high[byte + 1] << 8;
+    }
+    return (uint32_t) low[group] |
+           (((word >> shift) & ((1u << high_bits) - 1u)) << 8);
+}
+
+bool ggml_cpu_validate_tq1_tensor(const struct ggml_tensor * tensor) {
+    if (tensor == NULL || !ggml_type_is_tq1_v(tensor->type) || tensor->data == NULL ||
+        tensor->ne[0] <= 0 || tensor->ne[0] % QK_K != 0 || !ggml_is_contiguous(tensor)) {
+        return false;
+    }
+    const struct ggml_tq1_tensor_context * tq1 =
+        (const struct ggml_tq1_tensor_context *) tensor->extra;
+    if (tq1 == NULL || tq1->magic != GGML_TQ1_CONTEXT_MAGIC ||
+        tq1->codebook == NULL || tq1->legal == NULL) {
+        return false;
+    }
+    const bool v11 = tensor->type == GGML_TYPE_TQ1_V11 ||
+                     tensor->type == GGML_TYPE_TQ1_V11_R ||
+                     tensor->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const bool row_mode = tensor->type == GGML_TYPE_TQ1_V11_R ||
+                          tensor->type == GGML_TYPE_TQ1_V12_R ||
+                          tensor->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const bool affine = tensor->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const int high_bits = v11 ? 3 : 4;
+    const int raw_bytes = v11 ? 44 : 48;
+    const int block_bytes = (int) ggml_type_size(tensor->type);
+    const int index_offset = row_mode ? 0 : 2;
+    const uint32_t index_count = 1u << (high_bits + 8);
+    if (tq1->index_count != index_count) return false;
+    const int64_t block_count = ggml_nelements(tensor) / QK_K;
+    const uint8_t * data = (const uint8_t *) tensor->data;
+    for (int64_t b = 0; b < block_count; ++b) {
+        const uint8_t * block = data + b * block_bytes;
+        if (!row_mode) {
+            const ggml_fp16_t raw_scale = (ggml_fp16_t) block[0] |
+                                          (ggml_fp16_t) ((uint16_t) block[1] << 8);
+            const float scale = GGML_CPU_FP16_TO_FP32(raw_scale);
+            if (!isfinite(scale) || scale < 0.0f) return false;
+        }
+        for (int group = 0; group < 32; ++group) {
+            const uint32_t index = ggml_tq1_v_index(block, index_offset, high_bits, group);
+            if (index >= index_count || !tq1->legal[index]) return false;
+        }
+        if (affine) {
+            for (int byte = 0; byte < 4; ++byte) {
+                if ((block[raw_bytes + byte] & 15) > 11 ||
+                    (block[raw_bytes + byte] >> 4) > 11) return false;
+            }
+        }
+    }
+    return true;
+}
+
+static int8_t ggml_tq1_v_round_even(float value) {
+    float lower = floorf(value);
+    const float fraction = value - lower;
+    if (fraction > 0.5f || (fraction == 0.5f && fmodf(fabsf(lower), 2.0f) == 1.0f)) {
+        lower += 1.0f;
+    }
+    if (lower > 127.0f) lower = 127.0f;
+    if (lower < -127.0f) lower = -127.0f;
+    return (int8_t) lower;
+}
+
+static void ggml_compute_forward_mul_mat_tq1_v(
+        const struct ggml_compute_params * params,
+              struct ggml_tensor * dst) {
+    const struct ggml_tensor * src0 = dst->src[0];
+    const struct ggml_tensor * src1 = dst->src[1];
+    GGML_TENSOR_BINARY_OP_LOCALS
+
+    GGML_ASSERT(src1->type == GGML_TYPE_F32);
+    GGML_ASSERT(ne00 == ne10 && ne00 % QK_K == 0);
+    GGML_ASSERT(nb00 == ggml_type_size(src0->type));
+    GGML_ASSERT(nb10 == sizeof(float));
+    GGML_ASSERT(nb0 == sizeof(float));
+
+    const struct ggml_tq1_tensor_context * tq1 =
+        (const struct ggml_tq1_tensor_context *) src0->extra;
+    GGML_ASSERT(tq1 != NULL && tq1->magic == GGML_TQ1_CONTEXT_MAGIC);
+    GGML_ASSERT(tq1->codebook != NULL && tq1->legal != NULL);
+
+    const bool v11 = src0->type == GGML_TYPE_TQ1_V11 ||
+                     src0->type == GGML_TYPE_TQ1_V11_R ||
+                     src0->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const bool row_mode = src0->type == GGML_TYPE_TQ1_V11_R ||
+                          src0->type == GGML_TYPE_TQ1_V12_R ||
+                          src0->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const bool affine = src0->type == GGML_TYPE_TQ1_V11_J_A4_R;
+    const int high_bits = v11 ? 3 : 4;
+    const int raw_bytes = v11 ? 44 : 48;
+    const int block_bytes = (int) ggml_type_size(src0->type);
+    const int index_offset = row_mode ? 0 : 2;
+    GGML_ASSERT(tq1->index_count == (uint32_t) (1u << (high_bits + 8)));
+
+    const int64_t activation_rows = ne11 * ne12 * ne13;
+    const size_t qbytes = (size_t) activation_rows * ne10;
+    const size_t scale_offset = (qbytes + sizeof(float) - 1) & ~(sizeof(float) - 1);
+    GGML_ASSERT(params->wdata != NULL);
+    GGML_ASSERT(params->wsize >= scale_offset + (size_t) activation_rows * sizeof(float));
+    int8_t * qdata = (int8_t *) params->wdata;
+    float * scales = (float *) ((uint8_t *) params->wdata + scale_offset);
+
+    // Quantize each logical token exactly once, then share it across all output rows.
+    for (int64_t ar = params->ith; ar < activation_rows; ar += params->nth) {
+        const int64_t i11 = ar % ne11;
+        const int64_t rem = ar / ne11;
+        const int64_t i12 = rem % ne12;
+        const int64_t i13 = rem / ne12;
+        const float * x = (const float *) ((const char *) src1->data +
+            i11 * nb11 + i12 * nb12 + i13 * nb13);
+        float maximum = 0.0f;
+        for (int64_t k = 0; k < ne10; ++k) {
+            GGML_ASSERT(isfinite(x[k]));
+            const float value = fabsf(x[k]);
+            if (value > maximum) maximum = value;
+        }
+        const float scale = maximum / 127.0f;
+        int8_t * q = qdata + ar * ne10;
+        for (int64_t k = 0; k < ne10; ++k) {
+            q[k] = scale > 0.0f ? ggml_tq1_v_round_even(x[k] / scale) : 0;
+        }
+        scales[ar] = scale;
+    }
+    ggml_barrier(params->threadpool);
+
+    const int64_t r2 = ne12 / ne02;
+    const int64_t r3 = ne13 / ne03;
+    const int64_t result_count = ne01 * activation_rows;
+    const int64_t blocks_per_row = ne00 / QK_K;
+    for (int64_t task = params->ith; task < result_count; task += params->nth) {
+        const int64_t n = task % ne01;
+        const int64_t ar = task / ne01;
+        const int64_t i11 = ar % ne11;
+        const int64_t rem = ar / ne11;
+        const int64_t i12 = rem % ne12;
+        const int64_t i13 = rem / ne12;
+        const int64_t i02 = i12 / r2;
+        const int64_t i03 = i13 / r3;
+        const uint8_t * row = (const uint8_t *) src0->data +
+            n * nb01 + i02 * nb02 + i03 * nb03;
+        const int8_t * q = qdata + ar * ne10;
+        int64_t integer_acc = 0;
+        int64_t affine_numerator = 0;
+        float block_acc = 0.0f;
+
+        for (int64_t b = 0; b < blocks_per_row; ++b) {
+            const uint8_t * block = row + b * block_bytes;
+            int64_t current = 0;
+            if (affine) {
+                for (int sub = 0; sub < 8; ++sub) {
+                    int64_t dot = 0;
+                    int64_t xsum = 0;
+                    for (int extra = 0; extra < 4; ++extra) {
+                        const int group = sub * 4 + extra;
+                        const uint32_t index = ggml_tq1_v_index(block, index_offset, high_bits, group);
+                        GGML_ASSERT(index < tq1->index_count && tq1->legal[index]);
+                        const int8_t * code = tq1->codebook + (size_t) index * 8;
+                        const int8_t * qa = q + b * QK_K + group * 8;
+                        for (int lane = 0; lane < 8; ++lane) {
+                            dot += (int32_t) qa[lane] * code[lane];
+                            xsum += qa[lane];
+                        }
+                    }
+                    const uint8_t byte = block[raw_bytes + (sub >> 1)];
+                    const uint8_t nibble = (sub & 1) ? byte >> 4 : byte & 15;
+                    const int mu_id = (nibble >> 2) & 3;
+                    GGML_ASSERT(nibble <= 11 && mu_id != 3);
+                    const int rho_num = 6 + (nibble & 3);
+                    const int mu_num = mu_id == 0 ? 0 : (mu_id == 1 ? 1 : -1);
+                    affine_numerator += (int64_t) rho_num * (8 * dot + mu_num * xsum);
+                }
+                continue;
+            }
+            for (int group = 0; group < 32; ++group) {
+                const uint32_t index = ggml_tq1_v_index(block, index_offset, high_bits, group);
+                GGML_ASSERT(index < tq1->index_count && tq1->legal[index]);
+                const int8_t * code = tq1->codebook + (size_t) index * 8;
+                const int8_t * qa = q + b * QK_K + group * 8;
+                for (int lane = 0; lane < 8; ++lane) {
+                    current += (int32_t) qa[lane] * code[lane];
+                }
+            }
+            if (row_mode) {
+                integer_acc += current;
+            } else {
+                const ggml_fp16_t raw_scale = (ggml_fp16_t) block[0] |
+                                              (ggml_fp16_t) ((uint16_t) block[1] << 8);
+                const float weight_scale = GGML_CPU_FP16_TO_FP32(raw_scale);
+                GGML_ASSERT(isfinite(weight_scale) && weight_scale >= 0.0f);
+                block_acc += weight_scale * (float) current;
+            }
+        }
+        float value;
+        if (affine) {
+            value = scales[ar] * ((float) affine_numerator / 64.0f);
+        } else if (row_mode) {
+            value = scales[ar] * (float) integer_acc;
+        } else {
+            value = scales[ar] * block_acc;
+        }
+        GGML_ASSERT(isfinite(value));
+        *(float *) ((char *) dst->data + n * nb0 + i11 * nb1 + i12 * nb2 + i13 * nb3) = value;
+    }
+}
