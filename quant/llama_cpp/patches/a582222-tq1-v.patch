+        binding->index_count = profile_count;
+        binding->codebook = book->expanded.data();
+        binding->legal = book->legal.data();
+        tensor_it->second->extra = binding.get();
+        pimpl->tq1_bindings.emplace_back(std::move(binding));
+    }
+    if (strict_ternary == has_affine) {
+        throw std::runtime_error("tq1.strict_ternary does not match the resolved profiles");
+    }
