+                throw std::runtime_error("invalid TQ1 row-scale tensor for '" + name + "'");
+            }
+        }
+        const uint32_t profile_count = expected_type == GGML_TYPE_TQ1_V12 || expected_type == GGML_TYPE_TQ1_V12_R ? 4096 : 2048;
+        llama_tq1_codebook_data * book = book_it->second;
+        if (book->legal.size() != profile_count) {
+            throw std::runtime_error("TQ1 codebook width is incompatible with tensor '" + name + "'");
+        }
+        auto binding = std::make_unique<ggml_tq1_tensor_context>();
