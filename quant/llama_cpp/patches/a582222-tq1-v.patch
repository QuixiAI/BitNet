+// Compact FIPS 180-4 SHA-256 used to verify model-embedded codebooks without
+// adding a crypto dependency to the model loader.
+static std::string llama_tq1_sha256(const std::vector<uint8_t> & input) {
+    static const uint32_t k[64] = {
+        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
+        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
+        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
+        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
+        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
+        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
+        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
+        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2,
+    };
+    uint32_t state[8] = {0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
+                         0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19};
+    auto rotr = [](uint32_t x, int n) { return (x >> n) | (x << (32 - n)); };
+    auto transform = [&](const uint8_t * block) {
+        uint32_t w[64];
+        for (int i = 0; i < 16; ++i) {
+            w[i] = (uint32_t) block[4*i] << 24 | (uint32_t) block[4*i + 1] << 16 |
+                   (uint32_t) block[4*i + 2] << 8 | block[4*i + 3];
+        }
+        for (int i = 16; i < 64; ++i) {
+            const uint32_t s0 = rotr(w[i - 15], 7) ^ rotr(w[i - 15], 18) ^ (w[i - 15] >> 3);
+            const uint32_t s1 = rotr(w[i - 2], 17) ^ rotr(w[i - 2], 19) ^ (w[i - 2] >> 10);
+            w[i] = w[i - 16] + s0 + w[i - 7] + s1;
+        }
+        uint32_t a = state[0], b = state[1], c = state[2], d = state[3];
+        uint32_t e = state[4], f = state[5], g = state[6], h = state[7];
+        for (int i = 0; i < 64; ++i) {
+            const uint32_t s1 = rotr(e, 6) ^ rotr(e, 11) ^ rotr(e, 25);
+            const uint32_t ch = (e & f) ^ (~e & g);
+            const uint32_t t1 = h + s1 + ch + k[i] + w[i];
+            const uint32_t s0 = rotr(a, 2) ^ rotr(a, 13) ^ rotr(a, 22);
+            const uint32_t maj = (a & b) ^ (a & c) ^ (b & c);
+            const uint32_t t2 = s0 + maj;
+            h = g; g = f; f = e; e = d + t1; d = c; c = b; b = a; a = t1 + t2;
+        }
+        state[0] += a; state[1] += b; state[2] += c; state[3] += d;
+        state[4] += e; state[5] += f; state[6] += g; state[7] += h;
+    };
+    size_t offset = 0;
+    while (input.size() - offset >= 64) {
+        transform(input.data() + offset);
+        offset += 64;
+    }
+    uint8_t final_blocks[128] = {};
+    const size_t remain = input.size() - offset;
+    if (remain) std::memcpy(final_blocks, input.data() + offset, remain);
+    final_blocks[remain] = 0x80;
+    const size_t padded = remain < 56 ? 64 : 128;
+    const uint64_t bit_count = (uint64_t) input.size() * 8;
+    for (int i = 0; i < 8; ++i) final_blocks[padded - 1 - i] = (uint8_t) (bit_count >> (8*i));
+    transform(final_blocks);
+    if (padded == 128) transform(final_blocks + 64);
+    static const char hex[] = "0123456789abcdef";
+    std::string result(64, '0');
+    for (int i = 0; i < 8; ++i) {
+        for (int byte = 0; byte < 4; ++byte) {
+            const uint8_t value = (uint8_t) (state[i] >> (24 - 8*byte));
+            result[8*i + 2*byte] = hex[value >> 4];
+            result[8*i + 2*byte + 1] = hex[value & 15];
+        }
+    }
+    return result;
+}
+
+static bool llama_tq1_is_sha256(const std::string & value) {
+    if (value.size() != 64) {
+        return false;
+    }
+    return std::all_of(value.begin(), value.end(), [](unsigned char ch) {
+        return (ch >= '0' && ch <= '9') || (ch >= 'a' && ch <= 'f');
+    });
+}
+
+static std::string llama_tq1_sha256(const std::string & input) {
+    return llama_tq1_sha256(std::vector<uint8_t>(input.begin(), input.end()));
+}
+
+struct llama_tq1_table_data {
+    std::string name;
+    uint8_t dtype_code;
+    std::vector<uint32_t> shape;
+    std::vector<uint8_t> payload;
+};
+
+template<typename T>
+static void llama_tq1_append_le(std::vector<uint8_t> & out, T value) {
+    for (size_t i = 0; i < sizeof(T); ++i) out.push_back((uint8_t) (value >> (8*i)));
+}
+
+static std::string llama_tq1_codebook_sha256(
+        const std::string & index_format,
+        const std::string & encoding,
+        const std::vector<llama_tq1_table_data> & tables) {
+    std::vector<uint8_t> stream;
+    const uint8_t magic[13] = {'T','Q','1','_','C','O','D','E','B','O','O','K',0};
+    stream.insert(stream.end(), magic, magic + 13);
+    llama_tq1_append_le<uint32_t>(stream, 1);
+    llama_tq1_append_le<uint16_t>(stream, (uint16_t) encoding.size());
+    stream.insert(stream.end(), encoding.begin(), encoding.end());
+    llama_tq1_append_le<uint16_t>(stream, (uint16_t) index_format.size());
+    stream.insert(stream.end(), index_format.begin(), index_format.end());
+    llama_tq1_append_le<uint16_t>(stream, (uint16_t) tables.size());
+    for (const auto & table : tables) {
+        llama_tq1_append_le<uint16_t>(stream, (uint16_t) table.name.size());
+        stream.insert(stream.end(), table.name.begin(), table.name.end());
+        stream.push_back(table.dtype_code);
+        stream.push_back((uint8_t) table.shape.size());
+        for (uint32_t dim : table.shape) llama_tq1_append_le<uint32_t>(stream, dim);
+        llama_tq1_append_le<uint64_t>(stream, table.payload.size());
+        stream.insert(stream.end(), table.payload.begin(), table.payload.end());
+    }
+    return llama_tq1_sha256(stream);
+}
+
+void llama_model_base::load_tq1_bindings(llama_model_loader & ml) {
+    std::unordered_map<std::string, ggml_tensor *> custom_tensors;
+    for (auto & [_, ctx_ptr] : ml.ctx_map) {
+        for (ggml_tensor * cur = ggml_get_first_tensor(ctx_ptr.get()); cur; cur = ggml_get_next_tensor(ctx_ptr.get(), cur)) {
+            if (llama_is_tq1_v_type(cur->type)) {
+                custom_tensors.emplace(cur->name, cur);
+            }
+        }
+    }
+    if (custom_tensors.empty()) {
+        return;
+    }
+
+    std::string spec_revision;
+    std::string quant_spec_json;
+    std::string quant_spec_sha256;
+    uint32_t format_version = 0;
+    uint32_t registry_revision = 0;
+    ml.get_key("tq1.spec_revision", spec_revision);
+    ml.get_key("tq1.format_version", format_version);
+    ml.get_key("tq1.ggml_type_registry_revision", registry_revision);
+    ml.get_key("tq1.quant_spec_json", quant_spec_json);
+    ml.get_key("tq1.quant_spec_sha256", quant_spec_sha256);
+    if (spec_revision != "1.0.0" || format_version != 1 || registry_revision != 1 ||
+        !llama_tq1_is_sha256(quant_spec_sha256) ||
+        llama_tq1_sha256(quant_spec_json) != quant_spec_sha256) {
+        throw std::runtime_error("unsupported or incomplete TQ1 format identity");
+    }
+
+    std::string source_model;
+    std::string source_revision;
+    ml.get_key("tq1.source_model", source_model);
+    ml.get_key("tq1.source_revision", source_revision);
+    if (source_model.empty() || source_revision.empty()) {
+        throw std::runtime_error("TQ1 model provenance is incomplete");
+    }
+
+    bool strict_ternary = false;
+    ml.get_key("tq1.strict_ternary", strict_ternary);
+
+    std::string activation_mode;
+    ml.get_key("tq1.activation_mode", activation_mode);
+    if (activation_mode != "a8_token") {
+        throw std::runtime_error("TQ1 llama.cpp revision 1 requires activation_mode=a8_token");
+    }
+
+    std::vector<std::string> tensor_names;
+    std::vector<std::string> tensor_codebooks;
+    std::vector<std::string> tensor_profiles;
+    std::vector<std::string> tensor_scales;
+    ml.get_arr("tq1.tensor.names", tensor_names);
+    ml.get_arr("tq1.tensor.codebook_ids", tensor_codebooks);
+    ml.get_arr("tq1.tensor.profiles", tensor_profiles);
+    ml.get_arr("tq1.tensor.scale_names", tensor_scales);
+    if (tensor_names.size() != tensor_codebooks.size() || tensor_names.size() != tensor_profiles.size() ||
+        tensor_names.size() != tensor_scales.size() || tensor_names.size() != custom_tensors.size()) {
+        throw std::runtime_error("TQ1 tensor binding metadata does not match the custom tensor inventory");
+    }
+
+    std::vector<std::string> codebook_ids;
+    uint32_t codebook_count = 0;
+    ml.get_arr("tq1.codebook.ids", codebook_ids);
+    ml.get_key("tq1.codebook.count", codebook_count);
+    if (codebook_ids.size() != codebook_count) {
+        throw std::runtime_error("TQ1 codebook count does not match tq1.codebook.ids");
+    }
+
+    auto read_aux = [&](const std::string & name, std::initializer_list<int64_t> dims) {
+        ggml_tensor * tensor = ml.require_tensor_meta(name);
+        if (tensor->type != GGML_TYPE_I8) {
+            throw std::runtime_error("TQ1 codebook tensor '" + name + "' must be I8");
+        }
+        size_t axis = 0;
